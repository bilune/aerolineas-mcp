{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": null,
  "outputDirectory": null,
  "regions": ["gru1"],
  "functions": {
    "api/mcp.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/favicon.ico", "destination": "/api/favicon" },
    {
      "source": "/.well-known/oauth-authorization-server",
      "destination": "/api/oauth/discovery-as"
    },
    {
      "source": "/.well-known/oauth-protected-resource",
      "destination": "/api/oauth/discovery-rs"
    },
    {
      "source": "/.well-known/oauth-protected-resource/api/mcp",
      "destination": "/api/oauth/discovery-rs"
    },
    { "source": "/oauth/authorize", "destination": "/api/oauth/authorize" },
    { "source": "/oauth/token", "destination": "/api/oauth/token" },
    { "source": "/oauth/register", "destination": "/api/oauth/register" }
  ]
}
