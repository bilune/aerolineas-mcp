# Copy to .env and fill in. None of these are committed.
# Vercel production env vars: set the same names via `vercel env add ... production`.

# === OAuth (required) ===
JWT_SECRET=                          # openssl rand -hex 32
ACCESS_PASSWORD=                     # what you type in the consent screen

# === Upstream API (required) ===
# Base URL of the airline's HTTP API (no trailing slash).
UPSTREAM_API_BASE=https://api.example.com
# Path on UPSTREAM_API_BASE for the flight offers endpoint.
UPSTREAM_OFFERS_PATH=/v1/flights/offers
# Public web origin used in Origin / Referer headers (matches what a browser would send).
UPSTREAM_WEB_ORIGIN=https://www.example.com
# HTML page on the upstream site that embeds window.__ACCESS_TOKEN__ and
# window.__TOKEN_EXPIRATION__ (scraped to obtain a bearer for the API).
UPSTREAM_TOKEN_URL=https://www.example.com/some-page-with-token

# === Upstream API (optional) ===
UPSTREAM_CHANNEL_ID=WEB              # value of the x-channel-id header
UPSTREAM_LOCALE=en-US                # accept-language
UPSTREAM_USER_AGENT=                 # leave empty to use a recent Chrome UA

# === Booking deep-link (optional) ===
# If set, search_flights and find_best_combinations return a bookingUrl
# pointing here with shoppingId + legs pre-filled.
BOOKING_URL_BASE=https://www.example.com/flights-offers

# === MCP server identity (optional) ===
SERVER_NAME=flight-search-mcp
SERVER_TITLE=Flight Search MCP
SERVER_DESCRIPTION=MCP wrapper for an airline's public flight inventory API.
SERVER_WEBSITE_URL=
OAUTH_RESOURCE_NAME=Flight Search MCP

# === MCP resources URI scheme (optional) ===
# Stable scheme advertised in resource URIs (clients cache by URI).
MCP_RESOURCE_URI_SCHEME=flightsearch
